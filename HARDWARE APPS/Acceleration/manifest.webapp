{
  "version": "1.0.0",
  "name": "App: Accelerometer Sensor",
  "description": "Show accelerometer data from the device sensor.",
  "launch_path": "/index.html",
  "icons": {
    "56": "/icons/icon56.png",
    "112": "/icons/icon112.png"
  },
