{
  "version": "1.0.1",
  "name": "KaiNav Guide",
  "description": "Guía de navegación por teclado con scroll robusto.",
  "launch_path": "/KeyBoardApp.html",
  "type": "privileged",
  "icons": {
    "56": "/img/icons/icon56.png",
    "128": "/img/icons/icon128.png"
  },
  "developer": {
    "name": "Guillermo González Martín",
    "url": "https://github.com/ggonzalez1998"
  },
  "permissions": {
    "systemXHR": {
      "description": "Ejemplos de carga de datos remotos."
    }
  },
  "locales": {
    "en-US": { "name": "Nav Guide" },
    "es": { "name": "Guía Navegación" }
  },
  "default_locale": "es"
}
