{
  "version": "1.0.5",
  "name": "KaiNav Guide",
  "description": "Keyboard navigation guide with robust scrolling.",
  "launch_path": "/KeyBoardApp.html",
  "type": "privileged",
  "icons": {
    "56":   "/icons/icon-56x56.png",
    "112":  "/icons/icon-112x112.png",
    "128":  "/icons/icon-128x128.png"
  },
