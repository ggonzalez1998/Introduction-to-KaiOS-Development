      "description": "Examples of loading remote data."
    }
  },
  "locales": {
    "en": {
      "name": "D-Pad Navigation",
      "description": "Navigation for D-Pad with robust scrolling."
    },
    "es": {
      "name": "Navegación D-Pad",
      "description": "Navegación para D-Pad con desplazamiento robusto."
    }
  },
  "default_locale": "en-US"
}
